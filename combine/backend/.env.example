# ─── ORACLE backend configuration ────────────────────────────────────────────
# Copy to `.env` for local development. Defaults below run the zero-infra "lite"
# mode: in-memory knowledge base + cache + hashing embedder, no external services.

# ── App ──
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO
API_BASE_PATH=/api
# Comma-separated allowed origins for CORS (web dashboard, local dev, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Knowledge base repository ──
# memory   → in-memory KB loaded from app/data/seed_claims.json (no DB needed)
# postgres → Postgres + pgvector (production)
REPOSITORY_BACKEND=memory
DATABASE_URL=postgresql+psycopg2://oracle:oracle@localhost:5432/oracle

# ── Cache ──
# memory → in-process TTL cache (no Redis needed)
# redis  → Redis (production)
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# ── NLP ──
# hashing               → deterministic 384-dim hashing embedder (no torch, dev/demo)
# sentence-transformers → all-MiniLM-L6-v2 (production)
NLP_EMBEDDER=hashing
SIMILARITY_THRESHOLD=0.75
CHECKWORTHINESS_THRESHOLD=0.5

# ── External fact-check APIs (optional; heuristic fallback used when unset) ──
CLAIMBUSTER_API_KEY=
GOOGLE_FACTCHECK_API_KEY=

# ── Firebase Admin (optional locally; required in prod for token verification) ──
# Paste the service-account JSON as a single-line string, OR point to a file path.
FIREBASE_ADMIN_CREDENTIALS_JSON=
FIREBASE_ADMIN_CREDENTIALS_FILE=
FIREBASE_STORAGE_BUCKET=
# When Firebase Storage is unconfigured, generated truth cards are written here and
# served from /static so the full flow works locally.
LOCAL_STORAGE_DIR=.local_storage
PUBLIC_BASE_URL=http://localhost:8000

# ── Rate limiting (§14.5) ──
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=600

# ── Content limits ──
MAX_CONTENT_CHARS=5000
MAX_IMAGE_BYTES=10485760           # 10 MB
