# ORACLE web dashboard — environment variables
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Every value is optional at build time: the app is designed to render tasteful
# loading/empty/fallback states instead of crashing when something is missing.

# Base URL of the ORACLE backend (FastAPI). Include the /api suffix.
# Falls back to http://localhost:8000/api when unset.
VITE_API_BASE_URL=http://localhost:8000/api

# Mapbox GL access token for the live spread map (https://account.mapbox.com/access-tokens/).
# Leave empty to show the "add a Mapbox token" fallback panel instead of the map.
VITE_MAPBOX_TOKEN=

# Firebase web app config (Firebase console -> Project settings -> General -> Your apps).
# Leave all of these empty to disable Firebase-backed features entirely.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
